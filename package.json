{
  "name": "three-in-line",
  "private": true,
  "type": "module",
  "scripts": {
    "install:web": "cd web && bun install --frozen-lockfile",
    "install:mobile": "cd mobile && bun install --frozen-lockfile",
    "install:contexts": "bun run install:web && bun run install:mobile",
    "web:dev": "bun run --cwd web dev",
    "web:build": "bun run --cwd web build",
    "web:preview": "bun run --cwd web preview",
    "web:test": "bun run --cwd web test",
    "web:test:watch": "bun run --cwd web test:watch",
    "web:typecheck": "bun run --cwd web typecheck",
    "web:deploy": "bun run --cwd web deploy",
    "web:deploy:pages": "bun run --cwd web deploy:pages",
    "dev:convex": "bash -lc 'set -a && source web/.env.local && set +a && bunx convex dev'",
    "mobile:start": "bun run --cwd mobile start",
    "mobile:start:dev-client": "bun run --cwd mobile start -- --dev-client --clear",
    "mobile:ios": "bun run --cwd mobile ios",
    "mobile:android": "bun run --cwd mobile android",
    "mobile:web": "bun run --cwd mobile web",
    "mobile:typecheck": "bun run --cwd mobile typecheck",
    "mobile:build:ios": "bun run --cwd mobile expo run:ios",
    "lint": "bunx @biomejs/biome check --write .",
    "typecheck": "bun run web:typecheck && bun run mobile:typecheck"
  }
}
